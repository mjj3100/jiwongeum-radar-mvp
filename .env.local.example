# 이 파일을 복사해 .env.local로 만들고 실제 값을 채우세요.
# .env.local은 .gitignore에 의해 git에 올라가지 않습니다.

NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...   # 공개 가능 (브라우저 노출 OK)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...            # 절대 비밀. 서버 전용. RLS 우회

ANTHROPIC_API_KEY=sk-ant-api03-...                 # 비밀

NEXT_PUBLIC_LITTLY_URL_BUNDLE=https://litt.ly/<slug-bundle>   # 전자책+진단리포트 결제 링크
NEXT_PUBLIC_LITTLY_URL_STARTER=https://litt.ly/<slug-starter> # Starter 구독(재구매) 결제 링크

# 발급 전에는 비워두면 시드 데이터로 폴백합니다.
KSTARTUP_API_KEY=
BIZINFO_API_KEY=

# /api/grants/sync 인증용. openssl rand -hex 32 등으로 직접 생성 (외부 서비스 아님).
CRON_SECRET=

# /admin/orders 접근 허용 이메일 (콤마로 여러 개 가능). 로그인 계정의 이메일과 비교.
ADMIN_EMAILS=
